# Copy to .env and fill in. Loaded automatically by python-dotenv.
# ----------------------------------------------------------------------

# Flask
FLASK_CONFIG=development          # development | production
SECRET_KEY=replace-with-a-long-random-string
PORT=5000

# Database -------------------------------------------------------------
# Leave unset to use a local SQLite file (zero-config demo).
# PostgreSQL (AWS RDS) example:
# DATABASE_URL=postgresql+psycopg2://scanner:password@your-db.rds.amazonaws.com:5432/scanner
# MySQL (AWS RDS) example:
# DATABASE_URL=mysql+pymysql://scanner:password@your-db.rds.amazonaws.com:3306/scanner
# DATABASE_URL=

# Uploads --------------------------------------------------------------
MAX_UPLOAD_MB=64

# Cloud storage (AWS S3) -----------------------------------------------
# Leave S3_BUCKET unset to store files on local disk instead.
# S3_BUCKET=my-scanner-bucket
AWS_REGION=us-east-1
S3_PREFIX=uploads/
# On EC2 use an IAM instance role instead of static keys. For local dev:
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...

# VirusTotal -----------------------------------------------------------
ENABLE_VIRUSTOTAL=true
VIRUSTOTAL_API_KEY=your-virustotal-api-key
VIRUSTOTAL_UPLOAD_UNKNOWN=false   # true = upload unknown files for analysis
VT_MALICIOUS_THRESHOLD=1          # engines flagging => "malicious"

# ClamAV ---------------------------------------------------------------
ENABLE_CLAMAV=false
CLAMAV_HOST=127.0.0.1
CLAMAV_PORT=3310
# CLAMAV_SOCKET=/var/run/clamav/clamd.ctl
